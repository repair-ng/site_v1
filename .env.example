# Leave these unset to run the app in payment DEMO MODE (fully clickable,
# simulated payment success — good for testing the flow before you have
# real OPay credentials).

# From your OPay merchant dashboard
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=

# https://api.opaycheckout.com for live, https://testapi.opaycheckout.com for sandbox
OPAY_API_BASE=

# Your deployed app URL, e.g. https://fixam.vercel.app (no trailing slash)
APP_BASE_URL=
