# Leave these unset to run the app in payment DEMO MODE (fully clickable,
# simulated payment success — good for testing the flow before you have
# real Paystack credentials).

# From your Paystack dashboard: Settings -> API Keys & Webhooks
PAYSTACK_SECRET_KEY=

# Your deployed app URL, e.g. https://re-pair.vercel.app (no trailing slash)
APP_BASE_URL=
